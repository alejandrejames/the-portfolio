---
import "@/styles/global.css"
import { Mail } from "lucide-react"
import Github from "../../public/github.svg"
import Linkedin from "../../public/linkedin.svg"

import Layout from "@/layout/layout.astro"
import Section from "@/components/container/container.astro"
---
<Layout>
  <Section className="flex items-center h-screen">
    <div class="w-full flex items-center gap-10 max-md:flex-wrap max-md:justify-center">
      <div class="w-60 h-auto rounded-[50%]">
        <img class="aspect-square rounded-[50%] w-[100%] h-auto object-cover" src="/testphoto.png" alt="profile">
      </div>
      <div class="w-fit">
        <div class="flex items-center gap-5">
          <a href="#">
            <Github />
          </a>
          <a href="#">
            <Linkedin />
          </a>
          <a class="w-50" href="#">
            <Mail />
          </a>
        </div>
        <h1 class="my-5 scroll-m-20 border-b pb-2 text-5xl font-semibold tracking-tight max-md:text-3xl max-md:text-center">alejandre james</h1>
        <p class="leading-10">Full Stack Developer</p>
      </div>
    </div>
  </Section>
</Layout>
