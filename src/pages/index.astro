---
import "@/styles/global.css"
import Layout from "@/layout/layout.astro"

import { HeaderComponent } from "@/components/common/tsx/HeaderComponent"
import MainvisualComponent from "@/components/mainvisual/MainvisualComponent.astro"
import AboutComponent from "@/components/about/AboutComponent.astro"
import SkillsComponent from "@/components/skills/SkillsComponent.astro"
import ProjectsComponent from "@/components/projects/ProjectsComponent.astro"
import ExperienceComponent from "@/components/experience/ExperienceComponent.astro"
import ContactComponent from "@/components/contact/ContactComponent.astro"
import FooterComponent from "@/components/footer/FooterComponent.astro"
---

<Layout>
  <HeaderComponent client:load />
  <MainvisualComponent />
  <AboutComponent />
  <SkillsComponent />
  <ProjectsComponent />
  <ExperienceComponent />
  <ContactComponent />
  <FooterComponent />
</Layout>
