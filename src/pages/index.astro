---
import "@/styles/global.css"
import Layout from "@/layout/layout.astro"

const data = Astro.locals.webdata;

import SectionComponent from "@/components/common/astro/SectionComponent.astro"

// Sections
import MainvisualComponent from "@/components/mainvisual/MainvisualComponent.astro";
import AboutComponent from "@/components/about/AboutComponent.astro";
---

<Layout>
  <SectionComponent id="home" className="relative flex items-center">
    <MainvisualComponent />
  </SectionComponent>

  <SectionComponent id="about" className="flex items-center">
    <AboutComponent />
  </SectionComponent>
</Layout>
