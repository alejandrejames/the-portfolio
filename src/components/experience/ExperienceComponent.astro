---
import { TimelineLine } from "@/components/experience/TimelineLine"
import { TimelineEntry } from "@/components/experience/TimelineEntry"
import experienceJson from "@/assets/experience.json"
---

<section id="experience" class="relative py-28" style="background: #040b1a">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(59,130,246,0.3), transparent)"></div>

  <div class="max-w-5xl mx-auto px-6">
    <!-- Static: section heading -->
    <div class="mb-16">
      <p class="font-mono mb-2" style="font-size: 0.75rem; color: #3b82f6">04. git log --oneline</p>
      <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700; color: #f1f5f9; font-family: 'Space Grotesk', sans-serif; line-height: 1.2">
        My Dev <span class="gradient-text">Journey</span>
      </h2>
    </div>

    <div class="relative">
      <!-- Dynamic: animated vertical line -->
      <TimelineLine client:load />

      <!-- Dynamic: each timeline entry slides in via its own island -->
      <div class="space-y-10">
        {experienceJson.map((item, i) => (
          <TimelineEntry client:load item={item} index={i} />
        ))}
      </div>
    </div>
  </div>
</section>
