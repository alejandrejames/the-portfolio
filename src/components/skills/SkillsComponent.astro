---
import { SkillsTabs } from "@/components/skills/SkillsTabs"
import { SkillsMindset } from "@/components/skills/SkillsMindset"
import { SkillsStrip } from "@/components/skills/SkillsStrip"
import dataJson from "@/assets/data.json"

const { user, skills } = dataJson
const techstack = user.techstack
const extraSkills = user.extraSkills
---

<section id="skills" class="relative py-28" style="background: #040b1a">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(59,130,246,0.3), transparent)"></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Static: section heading -->
    <div class="mb-16">
      <p class="font-mono mb-2" style="font-size: 0.75rem; color: #3b82f6">{skills.eyebrow}</p>
      <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700; color: #f1f5f9; font-family: 'Space Grotesk', sans-serif; line-height: 1.2">
        {skills.headline} <span class="gradient-text">{skills.headlineAccent}</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-5 gap-12 mb-16">
      <!-- Dynamic: tabbed skill badges -->
      <div class="lg:col-span-3">
        <SkillsTabs client:load techstack={techstack} extraSkills={extraSkills} />
      </div>

      <!-- Dynamic: mindset cards -->
      <div class="lg:col-span-2">
        <SkillsMindset client:load cards={skills.mindset} />
      </div>
    </div>

    <!-- Dynamic: all-skills strip -->
    <SkillsStrip client:load techstack={techstack} extraSkills={extraSkills} />
  </div>
</section>
