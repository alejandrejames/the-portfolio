---
import { ParticleCanvas } from "@/components/mainvisual/ParticleCanvas"
import { TypingHeadline } from "@/components/mainvisual/TypingHeadline"
import { TerminalCard } from "@/components/mainvisual/TerminalCard"
import contactJson from "@/assets/contact.json"
import dataJson from "@/assets/data.json"

const { user, mainvisual } = dataJson
const name = user.nameDisplay

const ICON_MAP: Record<string, string> = {
  Github: "M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z",
  LinkedIn: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  Mail: "M0 3v18h24v-18h-24zm6.623 7.929l-4.623 5.712v-9.458l4.623 3.746zm-4.141-5.929h19.035l-9.517 7.713-9.518-7.713zm5.694 7.188l3.824 3.099 3.83-3.104 5.612 6.817h-18.779l5.513-6.812zm9.208-1.264l4.616-3.741v9.348l-4.616-5.607z",
  Globe: "M12 0C5.374 0 0 5.373 0 12c0 6.628 5.374 12 12 12 6.628 0 12-5.372 12-12 0-6.627-5.372-12-12-12zm0 2c1.678 0 3.275.42 4.68 1.157L14.5 5H9.5L7.32 3.157A9.96 9.96 0 0112 2zm-7.5 3.5l1.96 1.97A9.96 9.96 0 002 12c0 .34.017.678.05 1.01L4.5 11.5V9l-1.5-1.5 1.5-2zm15 0l-1.5 2L21.5 9v2.5l2.45 1.51c.033-.332.05-.67.05-1.01a9.96 9.96 0 00-4.5-8.5zM9.5 7h5l1.5 5-3 3-3-3 1.5-5zm-5.45 7.5L6.5 16l-1 4.5A9.968 9.968 0 012 12c0-.17.006-.338.017-.506L4.05 14.5zm14.9 0l2.033-2.006C21.994 11.662 22 11.83 22 12a9.968 9.968 0 01-3.5 7.5L17.5 15l2-1-1-2.5z",
}

const socials = contactJson
  .filter((c) => ["Github", "LinkedIn", "Mail"].includes(c.name))
  .map((c) => ({ label: c.name, href: c.url, iconKey: c.name }))
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden" style="background: #030712">
  <!-- Dynamic: particle canvas -->
  <ParticleCanvas client:load />

  <!-- Static overlays -->
  <div class="absolute inset-0 dot-grid opacity-30" style="z-index: 0"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(59,130,246,0.07) 0%, transparent 70%); z-index: 0"
  ></div>

  <!-- Static floating code snippets (lg+) -->
  {mainvisual.floaters.map((f) => (
    <div
      class="absolute hidden lg:block select-none pointer-events-none font-mono"
      style={`left: ${f.x}; top: ${f.y}; font-size: 0.7rem; color: rgba(59,130,246,0.25); z-index: 1`}
    >
      {f.text}
    </div>
  ))}

  <div class="relative z-10 max-w-7xl mx-auto px-6 py-32 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left column -->
      <div>
        <!-- Static: "Available for hire" badge -->
        <div
          class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full"
          style="background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.25)"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 cursor-blink"></span>
          <span class="font-mono" style="font-size: 0.7rem; color: #60a5fa">Available for hire</span>
        </div>

        <!-- Static: greeting line -->
        <p class="font-mono mb-2" style="font-size: 1rem; color: #60a5fa">
          {mainvisual.greeting}
        </p>

        <!-- Dynamic: glitch headline + typing effect -->
        <TypingHeadline
          client:load
          name={name}
          sequences={user.roles}
          headlinePrefix={mainvisual.headlinePrefix}
          rolePrefix={mainvisual.rolePrefix}
        />

        <!-- Static: description -->
        <p
          class="mb-8"
          style="font-size: 1rem; color: #64748b; line-height: 1.7; max-width: 480px; font-family: 'Space Grotesk', sans-serif"
        >
          {mainvisual.description}
        </p>

        <!-- Static: CTA buttons -->
        <div class="flex flex-wrap gap-3 mb-10">
          {mainvisual.ctas.map((cta) => (
            <a
              href={cta.href}
              class={`px-6 py-3 rounded-lg text-white transition-all duration-200 ${cta.variant === "primary" ? "hero-btn-primary" : "hero-btn-outline"}`}
              style={cta.variant === "primary"
                ? "background: linear-gradient(135deg, #2563eb, #3b82f6); box-shadow: 0 4px 20px rgba(59,130,246,0.35); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; font-weight: 500; text-decoration: none"
                : "background: transparent; border: 1px solid rgba(255,255,255,0.15); font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; font-weight: 500; text-decoration: none"}
            >
              {cta.label}
            </a>
          ))}
        </div>

        <!-- Static: social links -->
        <div class="flex items-center gap-3">
          {socials.map((s) => {
            const pathD = ICON_MAP[s.iconKey]
            return (
              <a
                href={s.href}
                aria-label={s.label}
                class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200 hero-social-link"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: #64748b"
              >
                {pathD && (
                  <svg viewBox="0 0 24 24" fill="currentColor" style="width: 16px; height: 16px">
                    <path d={pathD} />
                  </svg>
                )}
              </a>
            )
          })}
          <span style="color: #334155; font-size: 0.75rem; margin-left: 4px; font-family: 'Space Grotesk'">
            {mainvisual.socialsLabel}
          </span>
        </div>
      </div>

      <!-- Right column: Dynamic terminal card -->
      <TerminalCard
        client:load
        name={name}
        since={user.since}
        professional={user.professional}
        stackLabels={user.stackLabels}
      />
    </div>

    <!-- Static: scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 hero-scroll-hint" style="color: #334155">
      <span style="font-size: 0.65rem; font-family: 'JetBrains Mono'">scroll</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <polyline points="19 12 12 19 5 12"></polyline>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.5) !important;
  }
  .hero-btn-outline:hover {
    border-color: rgba(59, 130, 246, 0.6) !important;
    background: rgba(59, 130, 246, 0.08) !important;
  }
  .hero-social-link:hover {
    color: #60a5fa !important;
    border-color: rgba(59, 130, 246, 0.4) !important;
    background: rgba(59, 130, 246, 0.1) !important;
  }
  .hero-scroll-hint:hover {
    color: #60a5fa;
  }
</style>
