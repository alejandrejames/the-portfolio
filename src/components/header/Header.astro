---
import data from '../../../public/data.json'
import { Button } from "@/components/ui/button";

const pages = data.nav;
---

<nav class="
  fixed
  md:top-10
  left-[50%]
  flex
  align-middle
  justify-between
  rounded-[32px]
  mx-auto
  gap-3
  py-2
  px-3
  w-fit
  bg-slate-800 
  bg-opacity-75
  translate-x-[-50%]
  max-md:top-2
  max-md:w-fit
  max-md:gap-2
  max-md:justify-center
  z-[9999]
">
  { pages.map(elementPage => (
    <Button className="rounded-[32px] bg-gray-600 text-slate-50 max-md:text-xs hover:text-black">
      <a href={ elementPage.url }>{ elementPage.text }</a>
    </Button>
  )) }
</nav>
