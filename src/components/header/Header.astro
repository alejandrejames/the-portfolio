---
import { Button } from "@/components/ui/button";

const pages = [
  { text : 'Home', url : '#home'},
  { text : 'About', url : '#about'},
  { text : 'Works', url : '#works'},
  { text : 'Contact', url : '#contain'}
];
---

<nav class="
  fixed
  md:top-20
  left-[50%]
  flex
  align-middle
  justify-between
  rounded-[32px]
  mx-auto
  gap-4
  py-2
  px-4
  w-fit
  bg-slate-800 
  bg-opacity-75
  translate-x-[-50%]
  max-md:bottom-0
  max-md:flex-wrap
  max-md:w-full
  max-md:gap-2
  max-md:justify-center
">
  { pages.map(elementPage => (
    <Button className="rounded-[32px] bg-gray-600 text-slate-50 max-md:text-xs">
      <a href={elementPage.url}>{elementPage.text}</a>
    </Button>
  ))}
</nav>